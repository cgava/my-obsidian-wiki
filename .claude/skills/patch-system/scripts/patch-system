#!/usr/bin/env bash
# patch-system — bash dispatcher for the Python patch_system package.
#
# Thin CLI shim : resolves PATCH_SYSTEM_ROOT and delegates argv to
# `python3 -m patch_system`. The flock on `patches/.lock` for mutating
# subcommands (apply / rollback / refresh / record) is owned by the Python
# layer (see patch_system/cli.py::_advisory_lock) — the shim never takes
# the lock itself, otherwise `exec python3` would inherit the held fd and
# Python's own fcntl.flock() on a second fd opened on the same file would
# deadlock against the inherited lock (Linux flock semantics: one OFD with
# LOCK_EX blocks LOCK_EX on a sibling OFD, even same-process).
#
# The shim still performs an early root-plausibility check for mutating
# subcommands so we fail loudly instead of scaffolding `patches/` into a
# wrong directory.
#
# Root resolution (layered, first match wins) :
#   1. ${PATCH_SYSTEM_ROOT}    explicit override
#   2. walk up from $(pwd) looking for patches/series.json
#   3. git rev-parse --show-toplevel
#   4. $(pwd)                  last resort
#
# See docs/260420-patch-system-design.md §2.2 + §5.7.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

_resolve_root() {
    if [[ -n "${PATCH_SYSTEM_ROOT:-}" ]]; then
        echo "${PATCH_SYSTEM_ROOT}"
        return
    fi

    local dir
    dir="$(pwd)"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/patches/series.json" ]]; then
            echo "$dir"
            return
        fi
        dir="$(dirname "$dir")"
    done

    local git_root
    if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
        echo "$git_root"
        return
    fi

    pwd
}

export PATCH_SYSTEM_ROOT="$(_resolve_root)"

# Make scripts/ dir importable so `python3 -m patch_system` resolves.
export PYTHONPATH="${SCRIPT_DIR}${PYTHONPATH:+:${PYTHONPATH}}"

# Determine whether the first non-flag argument is a mutating subcommand.
# The top-level parser accepts `--series` / `--vendor-root` before the
# subcommand, so we skip those (with their values) to find the verb.
_is_mutating_cmd() {
    local cmd=""
    local i=0
    while [[ $i -lt $# ]]; do
        local arg="${@:$((i+1)):1}"
        case "$arg" in
            --series|--vendor-root)
                i=$((i+2))
                continue
                ;;
            --series=*|--vendor-root=*)
                i=$((i+1))
                continue
                ;;
            -h|--help)
                return 1
                ;;
            -*)
                i=$((i+1))
                continue
                ;;
            *)
                cmd="$arg"
                break
                ;;
        esac
    done

    case "$cmd" in
        apply|rollback|refresh|record)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

if _is_mutating_cmd "$@"; then
    # Refuse to create patches/ in an implausible root — avoids silently
    # scaffolding into a wrong directory when cwd is outside any project.
    if [[ ! -d "${PATCH_SYSTEM_ROOT}/.git" && ! -f "${PATCH_SYSTEM_ROOT}/patches/series.json" ]]; then
        echo "patch-system: cannot resolve project root (no .git, no patches/series.json found)" >&2
        echo "  tried from: $(pwd)" >&2
        echo "  resolved:   ${PATCH_SYSTEM_ROOT}" >&2
        echo "  hint: set PATCH_SYSTEM_ROOT=/path/to/project" >&2
        exit 2
    fi
fi

exec python3 -m patch_system "$@"
